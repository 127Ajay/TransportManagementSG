<!DOCTYPE html>
<html>
<head>
    <title>@ViewBag.Title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                overflow-x: hidden;
            }

            .sidebar {
                height: 100vh;
                background-color: #343a40;
                color: white;
            }

                .sidebar a {
                    color: #adb5bd;
                    text-decoration: none;
                    display: block;
                    padding: 12px;
                }

                    .sidebar a:hover {
                        background-color: #495057;
                        color: #fff;
                    }

            .content {
                padding: 20px;
            }

            .navbar {
                background-color: #fff;
                border-bottom: 1px solid #ddd;
            }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row">

            <!-- LEFT SIDEBAR -->
            <div class="col-md-2 sidebar p-0">
                <h4 class="text-center py-3 border-bottom">Admin Panel</h4>

                <a href="@Url.Action("Dashboard", "Admin")">Dashboard</a>
                <a href="@Url.Action("Registration", "Admin")">User Registration</a>
                <a href="@Url.Action("Index", "User")">Users</a>
                <a href="@Url.Action("Index", "Role")">Roles</a>
                <a href="@Url.Action("Index", "User")">Logout</a>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-md-10">

                <!-- TOP NAVBAR -->
                <div class="navbar px-3 py-2">
                    <h5 class="mb-0">Welcome, Admin</h5>
                </div>

                <!-- PAGE CONTENT -->
                <div class="content">
                    @RenderBody()
                </div>

            </div>

        </div>
    </div>

</body>
</html>